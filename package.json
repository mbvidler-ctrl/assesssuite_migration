{
  "name": "base44-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "typecheck": "tsc -p ./jsconfig.json",
    "preview": "vite preview",
    "server": "node server/index.mjs",
    "selftest": "node server/selftest.mjs",
    "test:assurance": "node server/tests/run-assurance.mjs",
    "test:extraction-matrix": "node --test server/tests/extraction-matrix.test.mjs",
    "test:referral-browser": "playwright test --config e2e/referral-uploader/playwright.config.mjs",
    "test:referral-sdk-journey": "node --test server/tests/referral-sdk-journey.test.mjs",
    "test:referral-production-canary": "node --test server/tests/referral-production-canary.test.mjs",
    "canary:referral:production": "node --no-warnings scripts/referral-production-canary.mjs",
    "test:provider-probe": "node server/tests/provider-probe.mjs",
    "test:rollback-compatibility": "node --test server/tests/rollback-compatibility.test.mjs",
    "test:forward-rollback-compatibility": "node scripts/run-forward-rollback-compatibility.mjs",
    "test:rich-text-editor-security": "node --test server/tests/rich-text-editor-security.test.mjs",
    "test:safe-html-output": "node --test server/tests/safe-html-output.test.mjs",
    "test:signup-contract": "node --test server/tests/signup-contract.test.mjs",
    "test:production-parity-contract": "node --test server/tests/production-parity-contract.test.mjs",
    "parity:wave": "node server/tests/production-parity-wave.mjs run-wave",
    "parity:seed": "node server/tests/production-parity-cleanup.mjs seed",
    "parity:verify-seed": "node server/tests/production-parity-cleanup.mjs verify-seed",
    "parity:observe-wave": "node server/tests/production-parity-cleanup.mjs observe-wave",
    "parity:cleanup": "node server/tests/production-parity-cleanup.mjs cleanup-and-verify",
    "seed": "node server/seed.mjs",
    "validate:entry-guards": "node scripts/validate-entry-ts-guards.mjs",
    "check:prod-secrets": "node scripts/check-production-secrets.mjs",
    "deploy:prod": "node -e \"console.error('Direct production deployment is disabled; run production-prepare-release, then dispatch the reviewed default-branch production-deploy workflow with its sealed immutable evidence.'); process.exit(1)\""
  },
  "dependencies": {
    "@base44/sdk": "^0.8.35",
    "@base44/vite-plugin": "^1.0.24",
    "@hello-pangea/dnd": "^17.0.0",
    "@hookform/resolvers": "^4.1.2",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-aspect-ratio": "^1.1.2",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.3",
    "@radix-ui/react-context-menu": "^2.2.6",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-hover-card": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-navigation-menu": "^1.2.5",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-toggle": "^1.1.2",
    "@radix-ui/react-toggle-group": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tanstack/react-query": "^5.84.1",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "core-js": "^3.36.0",
    "date-fns": "^3.6.0",
    "embla-carousel-react": "^8.5.2",
    "framer-motion": "^11.16.4",
    "html2canvas": "^1.4.1",
    "input-otp": "^1.4.2",
    "lodash": "^4.17.21",
    "lucide-react": "^0.475.0",
    "moment": "^2.30.1",
    "next-themes": "^0.4.4",
    "quill": "2.0.2",
    "react": "^18.2.0",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.54.2",
    "react-hot-toast": "^2.6.0",
    "react-leaflet": "^4.2.1",
    "react-markdown": "^9.0.1",
    "react-resizable-panels": "^2.1.7",
    "react-router": "^7.2.0",
    "react-router-dom": "^7.2.0",
    "recharts": "^2.15.4",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.1",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.171.0",
    "vaul": "^1.1.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@playwright/test": "1.61.1",
    "@types/node": "^22.13.5",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.19.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^6.1.0"
  }
}
