VITE_BASE44_APP_ID=local-assesssuite
VITE_BASE44_BACKEND_URL=http://localhost:5173
ADMIN_EMAIL=admin@local.test
ADMIN_PASSWORD=change-me-local

# --- Stripe (optional; leave ALL of these unset to keep the default mock) ---
# Setting STRIPE_SECRET_KEY is the single switch that turns on real Stripe
# calls in the four payment functions (createCheckoutSession,
# createPortalSession, stripeWebhook, syncStripeSubscription). Unset = the
# deterministic mock in server/mocks/stripe.mjs serves everything (the
# running demo's default state). SELFTEST=1 always uses the mock even when a
# key is set. Activation steps:
# docs/stripe/20260708-stripe-activation-runbook.md
# Secret API key (test mode: sk_test_...). Dashboard: Developers -> API keys.
STRIPE_SECRET_KEY=
# Webhook endpoint signing secret (whsec_...). From `stripe listen` locally,
# or the dashboard webhook endpoint's "Signing secret" when deployed. In real
# mode webhook posts are rejected unless this is set and the signature
# verifies.
STRIPE_WEBHOOK_SECRET=
# Price ids (price_...) for the two plans createCheckoutSession offers
# (`plan: "monthly"` / `plan: "annual"`). Create a product with recurring
# prices in the Stripe dashboard (test mode) and paste the ids here. A
# priceId supplied in the request body takes precedence over these.
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_ANNUAL=
# Absolute origin used to build checkout success/cancel URLs, the billing
# portal return URL, and password-reset links (no trailing slash).
# Local dev: http://localhost:5173. Production: the canonical public origin
# (apex OR www — exactly the host users land on, or the post-checkout
# redirect strands them on a token-less origin).
APP_URL=http://localhost:5173

# --- Transactional email (optional; unset = outbox-only mock) ---
# Setting RESEND_API_KEY turns on real sends via https://api.resend.com for
# every platform email (OTP verification, password reset, admin registration
# notice, welcome-on-activation, invites, in-app feedback). Every send — real
# or mock — is also recorded to the SQLite outbox_email table as an audit
# log. SELFTEST=1 always stays outbox-only. Sender domain must be verified in
# Resend (SPF + DKIM + DMARC at the DNS host) before real sends deliver.
RESEND_API_KEY=
# Optional overrides (defaults shown; see server/email.mjs):
# EMAIL_FROM="AssessSuite <noreply@assesssuite.com>"
# EMAIL_REPLY_TO=admin@assesssuite.com
# EMAIL_ADMIN_NOTIFY=admin@assesssuite.com

# --- AI generation (optional locally; REQUIRED in production) ---
# Setting OPENAI_API_KEY is the single switch that turns on the real language
# model for every AI surface — InvokeLLM (nutrition advice, medication alerts,
# assessment recommendations, treatment protocols, SOAP assist, the report
# suite) and Whisper transcription. Unset OR SELFTEST=1 = the deterministic
# mock in server/mocks/schema-instantiator.mjs, which returns "Mock <field>
# value" placeholder strings. A per-prompt de-identification pass runs before
# egress (server/llm.mjs). NOTE: a missing key in production SILENTLY serves
# mock content into clinical records — scripts/check-production-secrets.mjs
# (npm run check:prod-secrets) fails the deploy if it is absent. Fly secrets are
# per-app: setting it on one app does NOT propagate to another.
OPENAI_API_KEY=
# Optional model overrides (defaults shown; see server/llm.mjs):
# OPENAI_MODEL_FAST=gpt-4.1-mini
# OPENAI_MODEL_QUALITY=gpt-4.1

# --- Launch switches ---
# Transcription (SOAP-note audio -> Whisper -> dissect) is OFF for users
# unless this is exactly '1': the Transcribe/Dissect UI hides (public
# settings) and server/functions/transcribeSession.mjs refuses calls.
# Recording itself stays available.
TRANSCRIPTION_ENABLED=
# Legal display status. Unset = release-candidate banners on /legal pages.
# Maxwell's go-live flip sets LEGAL_STATUS=effective plus an
# LEGAL_EFFECTIVE_DATE (e.g. "14 July 2026"). DISPLAY-ONLY: never bump
# SUITE_VERSION / LEGAL_SUITE_VERSION (RC-2026.07.19) at the flip — they are
# the immutable content identifier in acceptance events, and changing them
# forces re-acceptance for every user.
LEGAL_STATUS=
LEGAL_EFFECTIVE_DATE=
# Uploads store override. MUST be a real environment variable (Fly [env]),
# not .env.local — module init order resolves it before .env.local loads.
# Production: /app/server/data/uploads (on the persistent volume).
# UPLOADS_DIR=

# --- Referral upload and document extraction release gates ---
# Production provider egress occurs only when all three values below are set.
# Keep DOCUMENT_EXTRACTION_ENABLED unset/0 for rollback or until release
# verification records the approved health-data terms attestation.
DOCUMENT_EXTRACTION_ENABLED=
OPENAI_HEALTH_DATA_TERMS_CONFIRMED=
# Additional fail-closed gate for documents whose subject is under 13 or whose
# age is unknown. Set only after independently verified zero-data-retention
# evidence is recorded for the exact production provider project.
DOCUMENT_EXTRACTION_UNDER_13_ENABLED=
# Optional extraction model override (default: gpt-4.1-mini).
OPENAI_DOCUMENT_EXTRACTION_MODEL=

# Temporary referral files expire within 24 hours; failed/cancelled work is
# targeted for cleanup within one hour. Values may shorten, never lengthen,
# these ceilings.
UPLOAD_REFERRAL_TTL_HOURS=24
UPLOAD_FAILURE_CLEANUP_MINUTES=60
UPLOAD_CLEANUP_INTERVAL_MINUTES=15
FILE_ACCESS_URL_TTL_SECONDS=120
UPLOAD_AUDIT_LEGAL_HOLD=

# Bounded operational controls. Defaults in server/uploadRegistry.mjs remain
# in force when blank.
UPLOAD_MAX_REQUEST_BYTES=
UPLOAD_MAX_REFERRAL_BYTES=
UPLOAD_MAX_FILE_BYTES=
UPLOAD_USER_PER_MINUTE=
UPLOAD_ORG_PER_MINUTE=
UPLOAD_USER_DAILY_BYTES=
UPLOAD_ORG_DAILY_BYTES=
UPLOAD_GLOBAL_LIVE_BYTES=
DOCUMENT_EXTRACTION_MAX_CONCURRENCY=
DOCUMENT_EXTRACTION_USER_CONCURRENCY=
DOCUMENT_EXTRACTION_ORG_CONCURRENCY=
DOCUMENT_EXTRACTION_MAX_FILES=
DOCUMENT_EXTRACTION_USER_PER_MINUTE=
DOCUMENT_EXTRACTION_ORG_PER_MINUTE=
DOCUMENT_EXTRACTION_USER_DAILY_DOCUMENTS=
DOCUMENT_EXTRACTION_ORG_DAILY_DOCUMENTS=
DOCUMENT_EXTRACTION_USER_DAILY_COST_USD=
DOCUMENT_EXTRACTION_ORG_DAILY_COST_USD=
DOCUMENT_EXTRACTION_MONTHLY_CIRCUIT_USD=29
DOCUMENT_EXTRACTION_ESTIMATED_COST_PER_DOCUMENT_USD=
UPLOAD_AUDIT_RETENTION_DAYS=730

# Rollback image only: accepts exactly the listed suite identifiers while
# provider extraction is disabled. Startup fails if this is set together with
# DOCUMENT_EXTRACTION_ENABLED=1.
# LEGAL_COMPATIBILITY_ACCEPTED_VERSIONS=RC-2026.07.11,RC-2026.07.19

# Immutable build identity exposed by GET /api/version.
RELEASE_SHA=
BUILD_TIMESTAMP=

# Test-only controls. ASSESSSUITE_DB_PATH must name an isolated .db file.
# Outside SELFTEST, the smoke production-gate harness also requires
# NODE_ENV=test and the exact ASSESSSUITE_DB_PATH_ACK value embedded in
# scripts/smoke.mjs; production startup otherwise rejects the override.
# The fake URL must be a loopback full /v1/responses endpoint. The provider
# probe bypasses it and uses only synthetic fixtures after the exact explicit
# acknowledgement exported by server/documentExtraction.mjs.
# ASSESSSUITE_DB_PATH=
# DOCUMENT_EXTRACTION_TEST_BASE_URL=http://127.0.0.1:9999/v1/responses
# DOCUMENT_EXTRACTION_TEST_TIMEOUT_MS=150
# DOCUMENT_EXTRACTION_PROVIDER_PROBE=
# DOCUMENT_EXTRACTION_PROVIDER_PROBE_ACK=
